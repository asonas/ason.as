!!! 5
%html{ lang: "ja" }
  %head
    %title= "ason.as"
    %meta{ "http-equiv" => "Content-Type", content: "text/html; charset=UTF-8" }
    %meta{ name: "viewport", content: "width=device-width,initial-scale=1" }
    = display_meta_tags
    %link{ rel: "preconnect", href: "https://fonts.googleapis.com" }
    %link{ rel: "preconnect", href: "https://fonts.gstatic.com", crossorigin: "" }
    %link{ rel: "stylesheet", href: "https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;1,9..144,400&family=Zen+Kaku+Gothic+New:wght@400;500;700&family=Zen+Old+Mincho:wght@400;600;700&display=swap" }
    %script{ src: "https://kit.fontawesome.com/f10d15f462.js", crossorigin: "anonymous" }
    = javascript_include_tag 'site'
    %link{ rel: "author", href: "http://www.hatena.ne.jp/asonas/" }
    %meta{ name: "Hatena::Bookmark", content: "nocomment" }

  %body
    .container
      %header.masthead
        %a.brand{ href: "/" } ason.as
        %nav.site-nav
          %a{ href: "/" } トップ
          %a{ href: "/articles" } 記事一覧
          %a{ href: "/feed" } Feed
      %main
        = yield
      %footer.site-footer
        .social-links
          %a.social-link{ href: "https://github.com/asonas", "aria-label": "GitHub" }
            %i.fa.fa-github
          %a.social-link{ href: "https://twitter.com/asonas", "aria-label": "X / Twitter" }
            %i.fa.fa-twitter
          %a.social-link{ href: "https://instagram.com/asonas", "aria-label": "Instagram" }
            %i.fa.fa-instagram
          %a.social-link{ href: "https://www.flickr.com/photos/asonas", "aria-label": "Flickr" }
            %i.fa.fa-flickr
          %a.social-link{ href: "https://facebook.com/asonas.P", "aria-label": "Facebook" }
            %i.fa.fa-facebook
          %a.social-link{ href: "http://tumblr.ason.as/", "aria-label": "Tumblr" }
            %i.fa.fa-tumblr-square
          %a.social-link{ href: "http://www.amazon.co.jp/registry/wishlist/BLMOXOOR4JFK", "aria-label": "Amazon Wishlist" }
            %i.fa.fa-amazon
          %a.social-link{ href: "https://asonas.hatenadiary.org/", "aria-label": "はてなダイアリー" }
            %i.fa.fa-book
          %a.social-link{ href: "http://asonas.hatenablog.com/", "aria-label": "はてなブログ" }
            %img{ src: "/images/asonashatenablog.jpg", alt: "はてなブログ" }
        %p.colophon asonas a.k.a Yuya Fujiwara
