!!! 5
/ YoruMimizuku 専用ランディングのレイアウト。
/ ブログ本体の site.css / site.js は読み込まず、専用CSS(yorumimizuku.css)と
/ フォントのみを読み込むことで、ブログ側のスタイル・スクリプトと一切衝突させない。
%html{ lang: "en" }
  %head
    %meta{ charset: "UTF-8" }
    %meta{ name: "viewport", content: "width=device-width,initial-scale=1" }
    %title YoruMimizuku 夜ミミズク — Bluesky / AT Protocol native client
    %meta{ name: "description", content: "YoruMimizuku is a native desktop client for Bluesky and the AT Protocol. Single column with tabs, written in Swift rather than Electron, for macOS and Windows." }
    %link{ rel: "canonical", href: "https://ason.as/yorumimizuku/" }
    %meta{ property: "og:type", content: "website" }
    %meta{ property: "og:title", content: "YoruMimizuku 夜ミミズク" }
    %meta{ property: "og:description", content: "A native desktop client for Bluesky and the AT Protocol. Single column with tabs, native (not Electron), for macOS and Windows." }
    %meta{ property: "og:url", content: "https://ason.as/yorumimizuku/" }
    %meta{ property: "og:image", content: "https://ason.as/images/ogimage.png" }
    %meta{ name: "twitter:card", content: "summary_large_image" }
    %link{ rel: "preconnect", href: "https://fonts.googleapis.com" }
    %link{ rel: "preconnect", href: "https://fonts.gstatic.com", crossorigin: "" }
    - fonts_href = "https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;0,9..144,700;1,9..144,400&family=Zen+Kaku+Gothic+New:wght@400;500;700&display=swap"
    %link{ rel: "stylesheet", href: fonts_href, media: "print", onload: "this.media='all'" }
    %noscript
      %link{ rel: "stylesheet", href: fonts_href }
    %link{ rel: "stylesheet", href: "/stylesheets/yorumimizuku.css" }
  %body.ym-page
    = yield
